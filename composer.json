{
  "name": "alxarafe/resource-pdo",
  "description": "PDO adapter for alxarafe/resource-controller. Implements RepositoryContract, QueryContract, and TransactionContract using native PDO.",
  "version": "0.1.0",
  "type": "library",
  "license": "GPL-3.0-or-later",
  "keywords": ["pdo", "sql", "adapter", "crud", "resource-controller", "alxarafe"],
  "authors": [
    {
      "name": "Rafael San José",
      "email": "rsanjose@alxarafe.com",
      "homepage": "https://alxarafe.es",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-pdo": "*",
    "alxarafe/resource-controller": "dev-main || ^0.1"
  },
  "autoload": {
    "psr-4": {
      "Alxarafe\\ResourcePdo\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Alxarafe\\ResourcePdo\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "phpstan/phpstan": "^2.1",
    "vimeo/psalm": "^6.0"
  },
  "minimum-stability": "stable",
  "config": {
    "sort-packages": true
  }
}
